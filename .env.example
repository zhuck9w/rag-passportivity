# Имена переменных для .env (значения не коммитим).
NOTION_TOKEN=
NOTION_KB_PAGE_ID=
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Альтернативное имя того же ключа: если в .env он называется SUPABASE_SECRET,
# config.py подхватит и его (SUPABASE_SECRET_KEY имеет приоритет).
SUPABASE_SECRET=
SLACKBOT_OAUTH=
SLACKBOT_APPLEVEL=
# Прокси для всего исходящего трафика (формат http://логин:пароль@адрес:порт).
# Работает только при PROXY_ENABLED=true; иначе соединение прямое.
PROXY=
PROXY_ENABLED=false
# Модель переформулировщика. Пусто = дефолт из config.py (claude-sonnet-5).
# Откат на Haiku: REWRITE_MODEL=claude-haiku-4-5-20251001 (+ рестарт бота).
REWRITE_MODEL=
